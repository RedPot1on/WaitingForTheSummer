@page "{id:int}"
@model WaitingForTheSummer.Pages.Quests.DetailsModel
@{
    ViewData["Title"] = Model.Quest?.Title ?? "Квест";
}

@if (Model.Quest is null)
{
    <p>Квест не найден.</p>
    return;
}

<div class="player-page quest-details">
    <div class="text-center mb-3">
        @if (!string.IsNullOrEmpty(Model.Quest.IconPath))
        {
            <img src="@Model.Quest.IconPath" alt="" class="quest-icon-lg" />
        }
    </div>

    <h1 class="page-title">@Model.Quest.Title</h1>
    <p class="mb-2"><strong>Баллы за успех:</strong> @Model.Quest.Points</p>
    <p class="quest-details__desc">@Model.Quest.Description</p>

    @if (Model.Requirements.Count > 0)
    {
        <div class="quest-reqs mb-3">
            <div class="quest-reqs__label">Требования:</div>
            <ul class="quest-reqs__list">
            @foreach (var req in Model.Requirements)
            {
                <li class="@(req.IsMet ? "is-met" : "is-unmet")">
                    <span class="quest-reqs__mark">@(req.IsMet ? "✓" : "○")</span>
                    @req.Title
                </li>
            }
            </ul>
        </div>
    }
    else
    {
        <p class="text-muted">Стартовый квест — требования не нужны.</p>
    }

    @if (!Model.CanStart && !string.IsNullOrEmpty(Model.LockReason))
    {
        <div class="alert alert-secondary">@Model.LockReason</div>
    }

    <div class="action-stack">
        <a class="btn btn-outline-secondary btn-touch" asp-page="./Index">К доске</a>
        @if (Model.CanStart && !User.IsInRole("Admin"))
        {
            <form method="post">
                <button type="submit" class="btn btn-primary btn-touch w-100">Начать</button>
            </form>
        }
    </div>
</div>
