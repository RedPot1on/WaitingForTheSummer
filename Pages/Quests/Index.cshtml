@page
@model WaitingForTheSummer.Pages.Quests.IndexModel
@{
    ViewData["Title"] = "Квесты";
}

<div class="player-page">
    <div class="page-header mb-3">
        <h1 class="page-title mb-2">Доска квестов</h1>
        @if (Model.HasTakenQuest)
        {
            <a class="btn btn-warning btn-touch w-100 w-sm-auto" asp-page="/Rounds/Current">Мой квест</a>
        }
    </div>

    @if (Model.ActiveGameRound is null)
    {
        <div class="alert alert-warning">Сейчас нет активного раунда. Ждите, пока администратор его начнёт.</div>
    }
    else
    {
        <div class="alert alert-success">
            Идёт раунд № @Model.ActiveGameRound.Number.
            @if (Model.HasTakenQuest)
            {
                <span>Вы уже взяли квест — сменить его нельзя.</span>
            }
            else
            {
                <span>Можно взять один квест.</span>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info">@Model.StatusMessage</div>
    }

    <div class="quest-board">
    @foreach (var item in Model.Items)
    {
        var quest = item.Quest;
        <article class="quest-card @(item.IsSelectedInCurrentRound ? "quest-card--selected" : item.CanStart ? "quest-card--open" : "quest-card--locked")">
            <div class="quest-card__icon">
                @if (!string.IsNullOrEmpty(quest.IconPath))
                {
                    <img src="@quest.IconPath" alt="" class="quest-icon" />
                }
                else
                {
                    <div class="quest-icon-placeholder">@quest.Title.FirstOrDefault()</div>
                }
            </div>
            <h2 class="quest-card__title">@quest.Title</h2>

            @if (item.IsSelectedInCurrentRound)
            {
                <span class="badge text-bg-warning align-self-start">Ваш выбор в раунде</span>
            }
            else if (item.IsOnceCompleted)
            {
                <span class="badge text-bg-secondary align-self-start">Пройден (один раз)</span>
            }
            else if (item.CanStart)
            {
                <span class="badge text-bg-success align-self-start">Доступен</span>
            }
            else if (!string.IsNullOrEmpty(item.LockReason))
            {
                <span class="badge text-bg-light text-dark border align-self-start">@item.LockReason</span>
            }

            @if (item.Requirements.Count > 0)
            {
                <div class="quest-reqs">
                    <div class="quest-reqs__label">Требования:</div>
                    <ul class="quest-reqs__list">
                    @foreach (var req in item.Requirements)
                    {
                        <li class="@(req.IsMet ? "is-met" : "is-unmet")">
                            <span class="quest-reqs__mark">@(req.IsMet ? "✓" : "○")</span>
                            @req.Title
                        </li>
                    }
                    </ul>
                </div>
            }

            <div class="quest-card__actions">
                <a class="btn btn-outline-secondary btn-touch" asp-page="./Details" asp-route-id="@quest.Id">Описание</a>
                @if (item.CanStart)
                {
                    <form method="post" asp-page-handler="Start" asp-route-id="@quest.Id" class="quest-card__start">
                        <button type="submit" class="btn btn-primary btn-touch w-100">Начать</button>
                    </form>
                }
            </div>
        </article>
    }
    </div>

    @if (Model.Items.Count == 0)
    {
        <p class="text-muted">Пока нет опубликованных квестов.</p>
    }
</div>
