@page
@model WaitingForTheSummer.Pages.Rounds.CurrentModel
@{
    ViewData["Title"] = "Текущий раунд";
}

@if (Model.Round is null)
{
    <div class="alert alert-secondary">
        Сейчас нет активного раунда.
        <a asp-page="/Quests/Index">К доске квестов</a>
    </div>
}
else
{
    <div class="mb-3">
        <span class="badge text-bg-warning">Раунд в процессе</span>
    </div>
    <h1>@Model.Round.Quest.Title</h1>
    <p class="text-muted">Начат: @Model.Round.StartedAt.ToLocalTime().ToString("g")</p>

    <div class="quest-body border rounded p-3 mb-4">
        @Html.Raw(Model.Round.Quest.BodyContent)
    </div>

    <div class="alert alert-info">
        Ожидайте решения администратора (успех или провал). Пока раунд активен, другой квест выбрать нельзя.
    </div>

    <a class="btn btn-outline-secondary" asp-page="/Quests/Index">К доске</a>
}
