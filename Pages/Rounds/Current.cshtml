@page
@model WaitingForTheSummer.Pages.Rounds.CurrentModel
@{
    ViewData["Title"] = "Мой квест";
}

<div class="player-page">
@if (Model.Round is null)
{
    <div class="alert alert-secondary">
        @if (Model.ActiveGameRound is null)
        {
            <span>Сейчас нет активного раунда.</span>
        }
        else
        {
            <span>Раунд № @Model.ActiveGameRound.Number идёт, но вы ещё не взяли квест.</span>
        }
    </div>
    <a class="btn btn-primary btn-touch w-100" asp-page="/Quests/Index">К доске квестов</a>
}
else
{
    <div class="mb-3 d-flex flex-wrap gap-2">
        <span class="badge text-bg-warning">Раунд № @Model.Round.GameRound.Number</span>
        @if (Model.Round.Status == WaitingForTheSummer.Models.RoundStatus.InProgress)
        {
            <span class="badge text-bg-primary">Ожидает решения</span>
        }
        else if (Model.Round.Status == WaitingForTheSummer.Models.RoundStatus.Succeeded)
        {
            <span class="badge text-bg-success">Успех</span>
        }
        else
        {
            <span class="badge text-bg-danger">Провал</span>
        }
    </div>
    <h1 class="page-title">@Model.Round.Quest.Title</h1>
    <p class="text-muted">Взят: @Model.Round.StartedAt.ToLocalTime().ToString("g")</p>

    <div class="quest-body border rounded p-3 mb-4">
        @Html.Raw(Model.Round.Quest.BodyContent)
    </div>

    @if (Model.Round.Status == WaitingForTheSummer.Models.RoundStatus.InProgress)
    {
        <div class="alert alert-info">
            Квест зафиксирован на этот раунд — сменить его нельзя. Ожидайте решения администратора.
        </div>
    }

    <a class="btn btn-outline-secondary btn-touch w-100" asp-page="/Quests/Index">К доске</a>
}
</div>
