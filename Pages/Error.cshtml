@page
@model ErrorModel
@{
    ViewData["Title"] = "Ошибка";
}

<h1 class="text-danger">Что-то пошло не так</h1>
<p>Произошла ошибка. Подробности записаны в лог — покажите администратору код запроса ниже.</p>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Код запроса:</strong> <code>@Model.RequestId</code>
    </p>
}

<p><a asp-page="/Index">На главную</a></p>
