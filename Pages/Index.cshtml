@page
@model IndexModel
@{
    ViewData["Title"] = "WaitingForTheSummer";
}

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="text-center py-5">
        <h1 class="display-6">WaitingForTheSummer</h1>
        <p class="lead">Выбери квест и начни раунд.</p>
        <a class="btn btn-primary btn-lg" asp-page="/Quests/Index">К доске квестов</a>
        @if (User.IsInRole("Admin"))
        {
            <a class="btn btn-outline-secondary btn-lg ms-2" asp-page="/Admin/Index">Админка</a>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <h1 class="display-6">WaitingForTheSummer</h1>
        <p class="lead">Войдите, чтобы открыть доску квестов.</p>
        <a class="btn btn-primary btn-lg" asp-area="Identity" asp-page="/Account/Login">Войти</a>
    </div>
}
