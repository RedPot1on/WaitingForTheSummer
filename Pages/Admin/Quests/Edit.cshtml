@page "{id:int?}"
@model WaitingForTheSummer.Pages.Admin.Quests.EditModel
@{
    ViewData["Title"] = Model.Input.Id == 0 ? "Новый квест" : "Редактирование квеста";
}

<h1>@ViewData["Title"]</h1>

<form method="post" enctype="multipart/form-data" class="col-lg-8">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Input.Id" />
    <input type="hidden" asp-for="Input.ExistingIconPath" />

    <div class="mb-3">
        <label asp-for="Input.Title" class="form-label"></label>
        <input asp-for="Input.Title" class="form-control" />
        <span asp-validation-for="Input.Title" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Description" class="form-label"></label>
        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Input.Description" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.BodyContent" class="form-label"></label>
        <textarea asp-for="Input.BodyContent" class="form-control" rows="8"></textarea>
        <div class="form-text">Можно HTML: текст, ссылки, картинки.</div>
        <span asp-validation-for="Input.BodyContent" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.SortOrder" class="form-label"></label>
        <input asp-for="Input.SortOrder" class="form-control" />
    </div>
    <div class="form-check mb-2">
        <input asp-for="Input.IsPublished" class="form-check-input" />
        <label asp-for="Input.IsPublished" class="form-check-label"></label>
    </div>
    <div class="form-check mb-3">
        <input asp-for="Input.IsOnceOnly" class="form-check-input" />
        <label asp-for="Input.IsOnceOnly" class="form-check-label"></label>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Points" class="form-label"></label>
        <input asp-for="Input.Points" class="form-control" type="number" min="0" step="1" required />
        <div class="form-text">При успехе игрок получает эти баллы, при провале — 0.</div>
        <span asp-validation-for="Input.Points" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Иконка</label>
        @if (!string.IsNullOrEmpty(Model.Input.ExistingIconPath))
        {
            <div class="mb-2">
                <img src="@Model.Input.ExistingIconPath" alt="icon" class="quest-icon" />
            </div>
        }
        <input asp-for="IconFile" type="file" class="form-control" accept="image/*" />
    </div>

    <fieldset class="mb-3">
        <legend class="fs-6">Требования (AND)</legend>
        @foreach (var opt in Model.RequirementOptions)
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox"
                       name="SelectedRequirementIds" value="@opt.Id"
                       id="req-@opt.Id"
                       @(Model.SelectedRequirementIds.Contains(opt.Id) ? "checked" : null) />
                <label class="form-check-label" for="req-@opt.Id">@opt.Title</label>
            </div>
        }
        @if (Model.RequirementOptions.Count == 0)
        {
            <p class="text-muted mb-0">Других квестов пока нет.</p>
        }
    </fieldset>

    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a class="btn btn-link" asp-page="./Index">Отмена</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
