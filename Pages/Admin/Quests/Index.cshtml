@page
@model WaitingForTheSummer.Pages.Admin.Quests.IndexModel
@{
    ViewData["Title"] = "Квесты";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Квесты</h1>
    <a class="btn btn-primary" asp-page="./Edit">Создать квест</a>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Порядок</th>
            <th>Название</th>
            <th>Баллы</th>
            <th>Опубликован</th>
            <th>Один раз</th>
            <th>Требования</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var q in Model.Quests)
    {
        <tr>
            <td>@q.SortOrder</td>
            <td>@q.Title</td>
            <td>@q.Points</td>
            <td>@(q.IsPublished ? "да" : "нет")</td>
            <td>@(q.IsOnceOnly ? "да" : "нет")</td>
            <td>@q.RequirementSummary</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@q.Id">Изменить</a>
            </td>
        </tr>
    }
    </tbody>
</table>

<a asp-page="../Index">← Назад</a>
